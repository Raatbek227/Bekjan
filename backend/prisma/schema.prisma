generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  STRIPE
  CASH
}

enum LoyaltyTier {
  BRONZE
  SILVER
  GOLD
  VIP
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("roles")
}

model User {
  id                  String         @id @default(cuid())
  email               String         @unique
  name                String
  phone               String?
  passwordHash        String?
  avatarUrl           String?
  status              UserStatus     @default(PENDING)
  emailVerifiedAt     DateTime?
  verificationToken   String?
  resetPasswordToken  String?
  resetPasswordExpiry DateTime?
  googleId            String?        @unique
  roleId              String?
  role                Role?          @relation(fields: [roleId], references: [id])
  loyaltyTier         LoyaltyTier    @default(BRONZE)
  loyaltyPoints       Int            @default(0)
  orders              Order[]
  bookings            Booking[]
  reviews             Review[]
  wishlistItems       Wishlist[]
  cartItems           CartItem[]
  comments            Comment[]
  notifications       Notification[]
  activityLogs        ActivityLog[]
  refreshTokens       RefreshToken[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@map("users")
}

model RefreshToken {
  id                String    @id @default(cuid())
  jti               String    @unique
  tokenHash         String    @unique
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId String?
  userAgent         String?
  ipAddress         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
  @@map("refresh_tokens")
}

model ProductCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("product_categories")
}

model Product {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  sku         String?          @unique
  description String?
  specs       Json?
  price       Decimal          @db.Decimal(10, 2)
  salePrice   Decimal?         @db.Decimal(10, 2)
  stock       Int              @default(0)
  isFeatured  Boolean          @default(false)
  isActive    Boolean          @default(true)
  categoryId  String
  category    ProductCategory  @relation(fields: [categoryId], references: [id])
  images      ProductImage[]
  reviews     Review[]
  orderItems  OrderItem[]
  wishlist    Wishlist[]
  cartItems   CartItem[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("products")
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@map("product_images")
}

model ServiceCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  services    Service[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("service_categories")
}

model Service {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  description String?
  benefits    String[]
  durationMin Int
  priceFrom   Decimal         @db.Decimal(10, 2)
  gallery     Json?
  isActive    Boolean         @default(true)
  categoryId  String
  category    ServiceCategory @relation(fields: [categoryId], references: [id])
  bookings    Booking[]
  slots       BookingSlot[]
  staff       StaffServiceAssignment[]
  reviews     Review[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("services")
}

model StaffMember {
  id                 String                   @id @default(cuid())
  name               String
  email              String?                  @unique
  phone              String?
  roleTitle          String?
  avatarUrl          String?
  isActive           Boolean                  @default(true)
  serviceAssignments StaffServiceAssignment[]
  workingHours       WorkingHour[]
  slots              BookingSlot[]
  bookings           Booking[]
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@map("staff_members")
}

model StaffServiceAssignment {
  id        String      @id @default(cuid())
  staffId   String
  staff     StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([staffId, serviceId])
  @@map("staff_service_assignments")
}

model WorkingHour {
  id        String       @id @default(cuid())
  staffId   String?
  staff     StaffMember? @relation(fields: [staffId], references: [id], onDelete: Cascade)
  dayOfWeek Int
  opensAt   String
  closesAt  String
  isClosed  Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([staffId, dayOfWeek])
  @@map("working_hours")
}

model BookingSlot {
  id          String       @id @default(cuid())
  serviceId   String?
  service     Service?     @relation(fields: [serviceId], references: [id])
  staffId     String?
  staff       StaffMember? @relation(fields: [staffId], references: [id])
  startsAt    DateTime
  endsAt      DateTime
  capacity    Int          @default(1)
  bookedCount Int          @default(0)
  isBlocked   Boolean      @default(false)
  notes       String?
  bookings    Booking[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([serviceId, startsAt])
  @@index([staffId, startsAt])
  @@map("booking_slots")
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  userId          String?
  user            User?         @relation(fields: [userId], references: [id])
  status          OrderStatus   @default(PENDING)
  subtotal        Decimal       @db.Decimal(10, 2)
  discountTotal   Decimal       @default(0) @db.Decimal(10, 2)
  deliveryTotal   Decimal       @default(0) @db.Decimal(10, 2)
  total           Decimal       @db.Decimal(10, 2)
  billingInfo     Json
  deliveryInfo    Json?
  items           OrderItem[]
  payment         Payment?
  couponId        String?
  coupon          Coupon?       @relation(fields: [couponId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  @@map("order_items")
}

model Payment {
  id                String        @id @default(cuid())
  orderId           String?       @unique
  order             Order?        @relation(fields: [orderId], references: [id])
  bookingId         String?       @unique
  booking           Booking?      @relation(fields: [bookingId], references: [id])
  method            PaymentMethod
  status            PaymentStatus @default(PENDING)
  amount            Decimal       @db.Decimal(10, 2)
  providerPaymentId String?
  metadata          Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@map("payments")
}

model Booking {
  id           String        @id @default(cuid())
  bookingCode  String        @unique
  userId       String?
  user         User?         @relation(fields: [userId], references: [id])
  serviceId    String
  service      Service       @relation(fields: [serviceId], references: [id])
  vehicleType  String
  vehicleBrand String?
  vehicleModel String?
  vehicleYear  Int?
  startsAt     DateTime
  endsAt       DateTime?
  slotId       String?
  slot         BookingSlot?   @relation(fields: [slotId], references: [id])
  customerInfo Json
  status       BookingStatus @default(PENDING)
  staffId      String?
  staff        StaffMember?   @relation(fields: [staffId], references: [id])
  notes        String?
  payment      Payment?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("bookings")
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  title     String?
  content   String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id])
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reviews")
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@map("wishlists")
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String?
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cart_items")
}

model BlogCategory {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  posts     Blog[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("blog_categories")
}

model Blog {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  excerpt     String?
  content     String
  coverImage  String?
  likes       Int          @default(0)
  shares      Int          @default(0)
  isPublished Boolean      @default(false)
  publishedAt DateTime?
  categoryId  String
  category    BlogCategory @relation(fields: [categoryId], references: [id])
  comments    Comment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("blogs")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  blogId    String
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("comments")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   String
  title     String
  message   String
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime @default(now())

  @@map("notifications")
}

model Coupon {
  id            String   @id @default(cuid())
  code          String   @unique
  description   String?
  discountType  String
  discountValue Decimal  @db.Decimal(10, 2)
  startsAt      DateTime?
  endsAt        DateTime?
  usageLimit    Int?
  usedCount     Int      @default(0)
  isActive      Boolean  @default(true)
  orders        Order[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("coupons")
}

model Gallery {
  id          String   @id @default(cuid())
  title       String
  type        String
  category    String?
  beforeUrl   String?
  afterUrl    String?
  mediaUrl    String
  description String?
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("gallery")
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  message   String
  status    String   @default("NEW")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contacts")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@map("activity_logs")
}
